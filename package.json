{
  "name": "meeting-room-scheduling",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "selfsignedstart": "NODE_TLS_REJECT_UNAUTHORIZED=0 next start -p 3000",
    "selfsignedstartdev": "NODE_TLS_REJECT_UNAUTHORIZED=0 next start -p 3002",
    "build": "next build && node scripts/build-scheduler.js",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx jobs/scheduler.ts",
    "scheduler": "tsx jobs/EntraSync/scheduler-wrapper.ts",
    "scheduler:start": "tsx jobs/EntraSync/scheduler-wrapper.ts --schedule \"0 3 * * *\"",
    "build:scheduler": "esbuild jobs/EntraSync/scheduler-wrapper.ts --bundle --platform=node --outfile=dist/scheduler-wrapper.js"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
