datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "linux-musl-openssl-3.0.x"]
}

model User {
  id             Int      @id @default(autoincrement()) @map("user_id")
  name           String
  email          String   @unique
  emailVerified  Boolean  @default(false) @map("email_verified")
  image          String?
  employeeNumber String?  @map("employee_number")
  employeeActive Boolean  @default(true) @map("employee_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]
  userRole UserRole[]
  event    Event[]

  @@map("user")
}

model Session {
  id        Int      @id @default(autoincrement()) @map("user_session_id")
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_session")
}

model Account {
  id                    Int       @id @default(autoincrement()) @map("user_account_id")
  userId                Int       @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  idToken               String?   @map("id_token")
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_account")
}

//@@id([provider, providerAccountId])

model Verification {
  id         Int      @id @default(autoincrement()) @map("user_verification_id")
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("user_verification")
}

model Room {
  roomId         Int      @id @default(autoincrement()) @map("room_id")
  name           String
  color          String
  icon           String?  @default("none")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  roomScopeId    Int      @default(1) @map("room_scope_id")
  roomCategoryId Int      @default(1) @map("room_category_id")

  roomCategory RoomCategory   @relation(fields: [roomCategoryId], references: [roomCategoryId])
  roomScope    RoomScope      @relation(fields: [roomScopeId], references: [roomScopeId])
  event        Event[]
  roomProperty RoomProperty[]

  @@map("room")
}

model RoomCategory {
  roomCategoryId Int      @id @default(autoincrement()) @map("room_category_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  room           Room[]

  @@map("room_category")
}

model RoomProperty {
  roomPropertyId Int      @id @default(autoincrement()) @map("room_property_id")
  roomId         Int      @map("room_id")
  name           String
  value          String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  room Room @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  @@map("room_property")
}

model RoomScope {
  roomScopeId Int      @id @default(autoincrement()) @map("room_scope_id")
  name        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  accessLevel Int      @default(1) @map("access_level")
  room        Room[]

  @@map("room_scope")
}

//Member 1 or Many Roles, MemberRole

model UserRole {
  userRoleId Int      @id @default(autoincrement()) @map("user_role_id")
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [roleId], onDelete: Cascade)

  @@map("user_role")
}

model Role {
  roleId    Int      @id @default(autoincrement()) @map("role_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userRole           UserRole[]
  roleResourceAction RoleResourceAction[]
  // RolePermission     RolePermission[]

  @@map("role")
}

model RoleResourceAction {
  roleResourceActionId Int      @id @default(autoincrement()) @map("role_resource_action_id")
  roleId               Int      @map("role_id")
  resourceId           Int      @map("resource_id")
  actionId             Int      @map("action_id")
  permit               Boolean
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  role     Role     @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [resourceId], onDelete: Cascade)
  action   Action   @relation(fields: [actionId], references: [actionId], onDelete: Cascade)
  //RolePermission RolePermission[]

  @@map("role_resource_action")
}

//Events, Rooms, etc...
model Resource {
  resourceId Int      @id @default(autoincrement()) @map("resource_id")
  name       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  roleResourceAction RoleResourceAction[]

  @@map("resource")
}

model Action {
  actionId  Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roleResourceAction RoleResourceAction[]

  @@map("action")
}

/**
 * type = frequency
 * pattern = "ByDay"
 * totalOccurrences = Count
 * daySpan/week/month/year = Interval
 */

model Recurrence {
  recurrenceId             Int      @id @default(autoincrement()) @map("recurrence_id")
  recurrenceCancellationId Int?     @map("recurrence_cancellation_id")
  recurrenceExceptionId    Int?     @map("recurrence_exception_id")
  rule                     String
  startDate                DateTime @map("start_date")
  endDate                  DateTime @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event                  Event[]
  recurrenceCancellation RecurrenceCancellation? @relation(fields: [recurrenceCancellationId], references: [recurrenceCancellationId])
  recurrenceException    RecurrenceException?    @relation(fields: [recurrenceExceptionId], references: [recurrenceExceptionId])

  @@map("recurrence")
}

model RecurrenceCancellation {
  recurrenceCancellationId Int      @id @default(autoincrement()) @map("recurrence_cancellation_id")
  recurrenceDate           DateTime @map("recurrence_date")
  cancellationDate         DateTime @map("cancellation_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recurrence Recurrence[]

  @@map("recurrence_cancellation")
}

model RecurrenceException {
  recurrenceExceptionId Int      @id @default(autoincrement()) @map("recurrence_exception_id")
  recurrenceDate        DateTime @map("recurrence_date")
  rescheduledDate       DateTime @map("rescheduled_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  recurrence Recurrence[]

  @@map("recurrence_exception")
}

model Event {
  eventId  Int  @id @default(autoincrement()) @map("event_id")
  roomId   Int  @map("room_id")
  statusId Int  @map("status_id") //e.g. "confirmed", "tentative", "cancelled"
  userId   Int? @map("user_id") //who booked the event

  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  title       String
  description String

  recurrenceId Int?     @map("recurrence_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  recurrence Recurrence? @relation(fields: [recurrenceId], references: [recurrenceId], onDelete: Cascade)

  user User? @relation(fields: [userId], references: [id])

  room   Room    @relation(fields: [roomId], references: [roomId])
  status Status? @relation(fields: [statusId], references: [statusId])

  @@map("event")
}

model Status {
  statusId  Int      @id @default(autoincrement()) @map("status_id")
  key       String   @unique
  name      String
  icon      String?  @default("none")
  color     String?  @default("none")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event[]

  @@map("status")
}

model Configuration {
  configurationId Int      @id @default(autoincrement()) @map("configuration_id")
  key             String   @unique
  description     String?
  value           String
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("configuration")
}

/**
 * export interface IEvent {
 * id: number;
 * key: string;
 * startDate: string;
 * endDate: string;
 * title: string;
 * description: string;
 * room: IRoom;
 * parentEvent: IEvent | null;
 * }
 */

/**
 * //Resource 1 or Many Attributes
 * model Attribute {
 * attributeId Int      @id @default(autoincrement())
 * name        String
 * resourceId  Int
 * actionId    Int
 * createdAt   DateTime @default(now())
 * updatedAt   DateTime @updatedAt
 * resource Resource @relation(fields: [resourceId], references: [resourceId], onDelete: Cascade)
 * action   Action   @relation(fields: [actionId], references: [actionId], onDelete: Cascade)
 * }
 */
