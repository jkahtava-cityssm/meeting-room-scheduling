
model User {
  id            Int     @id @default(autoincrement()) @map("user_id")
  name          String  @db.NVarChar(255)
  email         String? @db.NVarChar(255)
  emailVerified Boolean @default(false) @map("email_verified")
  emailEnabled  Boolean @default(true) @map("email_enabled")
  image         String? @db.NVarChar(MAX)
  uuid          String? @db.NVarChar(36)
  externalId    String? @map("external_id") @db.NVarChar(255)
  department    String? @map("department") @db.NVarChar(255)
  jobTitle      String? @map("job_title") @db.NVarChar(255)
  supervisorId  Int?    @map("supervisor_id")
  isActive      Boolean @default(true) @map("is_active")
  isManaged     Boolean @default(true) @map("is_managed")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Audit fields (self)
  createdBy Int? @map("created_by")
  updatedBy Int? @map("updated_by")

  // Existing relations
  account     Account[]
  session     Session[]
  userRole    UserRole[]
  event       Event[]
  ssoprovider SSOProvider[]

  supervisor User?  @relation("EmployeeToSupervisor", fields: [supervisorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employees  User[] @relation("EmployeeToSupervisor")

  // Self-audit relations
  createdByUser User? @relation("UserCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User? @relation("UserUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  usersCreated User[] @relation("UserCreatedBy")
  usersUpdated User[] @relation("UserUpdatedBy")

  providerCreated SSOProvider[] @relation("ProviderCreatedBy")
  providerUpdated SSOProvider[] @relation("ProviderUpdatedBy")

  // Account audit back-relations
  accountsCreated Account[] @relation("AccountCreatedBy")
  accountsUpdated Account[] @relation("AccountUpdatedBy")

  // Session audit back-relations
  sessionsCreated Session[] @relation("SessionCreatedBy")
  sessionsUpdated Session[] @relation("SessionUpdatedBy")

  // Verification audit back-relations
  verificationsCreated Verification[] @relation("VerificationCreatedBy")
  verificationsUpdated Verification[] @relation("VerificationUpdatedBy")

  // Room audit back-relations
  roomsCreated Room[] @relation("RoomCreatedBy")
  roomsUpdated Room[] @relation("RoomUpdatedBy")

  // RoomCategory audit back-relations
  roomCategoriesCreated RoomCategory[] @relation("RoomCategoryCreatedBy")
  roomCategoriesUpdated RoomCategory[] @relation("RoomCategoryUpdatedBy")

  // EventItem audit back-relations
  EventItemsCreated EventItem[] @relation("EventItemCreatedBy")
  EventItemsUpdated EventItem[] @relation("EventItemUpdatedBy")

  // RoomProperty audit back-relations
  roomPropertiesCreated RoomProperty[] @relation("RoomPropertyCreatedBy")
  roomPropertiesUpdated RoomProperty[] @relation("RoomPropertyUpdatedBy")

  // RoomRole audit back-relations
  roomRolesCreated RoomRole[] @relation("RoomRoleCreatedBy")
  roomRolesUpdated RoomRole[] @relation("RoomRoleUpdatedBy")

  // Property audit back-relations
  propertiesCreated Property[] @relation("PropertyCreatedBy")
  propertiesUpdated Property[] @relation("PropertyUpdatedBy")

  // UserRole audit back-relations
  userRolesCreated UserRole[] @relation("UserRoleCreatedBy")
  userRolesUpdated UserRole[] @relation("UserRoleUpdatedBy")

  // Role audit back-relations
  rolesCreated Role[] @relation("RoleCreatedBy")
  rolesUpdated Role[] @relation("RoleUpdatedBy")

  // ResourceAction audit back-relations
  resourceActionsCreated ResourceAction[] @relation("ResourceActionCreatedBy")
  resourceActionsUpdated ResourceAction[] @relation("ResourceActionUpdatedBy")

  // RoleResourceAction audit back-relations
  roleResourceActionsCreated RoleResourceAction[] @relation("RoleResourceActionCreatedBy")
  roleResourceActionsUpdated RoleResourceAction[] @relation("RoleResourceActionUpdatedBy")

  // Resource audit back-relations
  resourcesCreated Resource[] @relation("ResourceCreatedBy")
  resourcesUpdated Resource[] @relation("ResourceUpdatedBy")

  // Action audit back-relations
  actionsCreated Action[] @relation("ActionCreatedBy")
  actionsUpdated Action[] @relation("ActionUpdatedBy")

  // Recurrence audit back-relations
  recurrencesCreated Recurrence[] @relation("RecurrenceCreatedBy")
  recurrencesUpdated Recurrence[] @relation("RecurrenceUpdatedBy")

  // RecurrenceCancellation audit back-relations
  recurrenceCancellationsCreated RecurrenceCancellation[] @relation("RecurrenceCancellationCreatedBy")
  recurrenceCancellationsUpdated RecurrenceCancellation[] @relation("RecurrenceCancellationUpdatedBy")

  // RecurrenceException audit back-relations
  recurrenceExceptionsCreated RecurrenceException[] @relation("RecurrenceExceptionCreatedBy")
  recurrenceExceptionsUpdated RecurrenceException[] @relation("RecurrenceExceptionUpdatedBy")

  // Event audit back-relations
  eventsCreated Event[] @relation("EventCreatedBy")
  eventsUpdated Event[] @relation("EventUpdatedBy")

  // Status audit back-relations
  statusesCreated Status[] @relation("StatusCreatedBy")
  statusesUpdated Status[] @relation("StatusUpdatedBy")

  // Configuration audit back-relations
  configurationsCreated Configuration[] @relation("ConfigurationCreatedBy")
  configurationsUpdated Configuration[] @relation("ConfigurationUpdatedBy")

  itemCreated Item[] @relation("ItemCreatedBy")
  itemUpdated Item[] @relation("ItemUpdatedBy")

  eventRecipientCreated EventRecipient[] @relation("EventRecipientCreatedBy")
  eventRecipientUpdated EventRecipient[] @relation("EventRecipientUpdatedBy")
  eventRecipients       EventRecipient[]

  eventRoomsCreated EventRoom[] @relation("EventRoomCreatedBy")
  eventRoomsUpdated EventRoom[] @relation("EventRoomUpdatedBy")

  systemProcessCreated SystemProcess[] @relation("SystemProcessCreatedBy")
  systemProcessUpdated SystemProcess[] @relation("SystemProcessUpdatedBy")

  @@map("user")
}

model Session {
  id               Int      @id @default(autoincrement()) @map("user_session_id")
  userId           Int      @map("user_id")
  token            String   @unique @db.VarChar(2048)
  expiresAt        DateTime @map("expires_at")
  ipAddress        String?  @map("ip_address") @db.NVarChar(255)
  userAgent        String?  @map("user_agent") @db.NVarChar(1000)
  impersonatedRole String?  @map("impersonated_role") @db.NVarChar(255)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  createdBy Int? @map("created_by")
  updatedBy Int? @map("updated_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdByUser User? @relation("SessionCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User? @relation("SessionUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_session")
}

model Account {
  id                    Int       @id @default(autoincrement()) @map("user_account_id")
  userId                Int       @map("user_id")
  accountId             String    @map("account_id") @db.VarChar(255)
  providerId            String    @map("provider_id") @db.VarChar(255)
  accessToken           String?   @map("access_token") @db.VarChar(Max)
  refreshToken          String?   @map("refresh_token") @db.VarChar(2048)
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?   @db.VarChar(255)
  idToken               String?   @map("id_token") @db.VarChar(2048)
  password              String?   @db.VarChar(255)
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  createdBy Int? @map("created_by")
  updatedBy Int? @map("updated_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdByUser User? @relation("AccountCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User? @relation("AccountUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_account")
}

model Verification {
  id         Int      @id @default(autoincrement()) @map("user_verification_id")
  identifier String @db.NVarChar(255) 
  value      String @db.NVarChar(4000)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdBy Int? @map("created_by")
  updatedBy Int? @map("updated_by")

  createdByUser User? @relation("VerificationCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User? @relation("VerificationUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_verification")
}

model SSOProvider {
  id             Int     @id @default(autoincrement()) @map("sso_provider_id")
  issuer         String @db.NVarChar(255)
  domain         String @db.NVarChar(255)
  oidcConfig     String? @map("oidc_config") @db.NVarChar(Max)
  samlConfig     String? @map("saml_config") @db.NVarChar(Max)
  userId         Int?    @map("user_id")
  providerId     String  @map("provider_id") @db.VarChar(255)
  organizationId String? @map("organization_id") @db.VarChar(255)

  createdBy Int? @map("created_by")
  updatedBy Int? @map("updated_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdByUser User? @relation("ProviderCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User? @relation("ProviderUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sso_provider")
}

model Room {
  roomId         Int      @id @default(autoincrement()) @map("room_id")
  name           String   @db.NVarChar(255)
  color          String   @db.NVarChar(255)
  icon           String?  @default("none") @db.NVarChar(255)
  publicFacing   Boolean  @default(false) @map("public_facing")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  roomCategoryId Int      @map("room_category_id")
  displayOrder   Int?     @map("display_order")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  roomCategory RoomCategory @relation(fields: [roomCategoryId], references: [roomCategoryId], onDelete: NoAction, onUpdate: NoAction)

  roomProperty RoomProperty[]
  roomRoles    RoomRole[]
  eventRooms   EventRoom[]

  createdByUser User @relation("RoomCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RoomUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

@@index([displayOrder])
  @@map("room")
}

model RoomCategory {
  roomCategoryId Int      @id @default(autoincrement()) @map("room_category_id")
  name           String   @db.NVarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  room           Room[]

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("RoomCategoryCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RoomCategoryUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("room_category")
}

model RoomProperty {
  roomPropertyId Int     @id @default(autoincrement()) @map("room_property_id")
  roomId         Int     @map("room_id")
  propertyId     Int     @map("property_id")
  value          String? @db.NVarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  room     Room     @relation(fields: [roomId], references: [roomId], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [propertyId])

  createdByUser User @relation("RoomPropertyCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RoomPropertyUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roomId, propertyId], name: "roomId_propertyId")
  @@map("room_property")
}

model RoomRole {
  roomRoleId Int      @id @default(autoincrement()) @map("room_role_id")
  roomId     Int      @map("room_id")
  roleId     Int      @map("role_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  room Room @relation(fields: [roomId], references: [roomId], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [roleId], onDelete: Cascade)

  createdByUser User @relation("RoomRoleCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RoomRoleUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roomId, roleId], name: "roomId_roleId_unique")
  @@index([roleId], name: "roomrole_role_idx")
  @@index([roomId], name: "roomrole_room_idx")
  @@map("room_role")
}

model Property {
  propertyId Int      @id @default(autoincrement()) @map("property_id")
  name       String   @unique @db.NVarChar(255)
  type       String   @db.NVarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("PropertyCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("PropertyUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  roomProperty RoomProperty[]

  @@map("property")
}

model UserRole {
  userRoleId Int      @id @default(autoincrement()) @map("user_role_id")
  userId     Int      @map("user_id")
  roleId     Int      @map("role_id")
  granted    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [roleId], onDelete: Cascade)

  createdByUser User @relation("UserRoleCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("UserRoleUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, roleId], name: "userId_roleId")
  @@map("user_role")
}

model Role {
  roleId    Int      @id @default(autoincrement()) @map("role_id")
  name      String   @db.NVarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("RoleCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RoleUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  userRole           UserRole[]
  roleResourceAction RoleResourceAction[]
  roomRoles          RoomRole[]

  @@map("role")
}

model ResourceAction {
  resourceActionId Int      @id @default(autoincrement()) @map("resource_action_id")
  resourceId       Int      @map("resource_id")
  actionId         Int      @map("action_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  resource           Resource             @relation(fields: [resourceId], references: [resourceId], onDelete: Cascade)
  action             Action               @relation(fields: [actionId], references: [actionId], onDelete: Cascade)
  roleResourceAction RoleResourceAction[] // Permissions for this resource-action pair

  createdByUser User @relation("ResourceActionCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("ResourceActionUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([resourceId, actionId]) // Pr duplicates
  @@map("resource_action")
}

model RoleResourceAction {
  roleResourceActionId Int      @id @default(autoincrement()) @map("role_resource_action_id")
  roleId               Int      @map("role_id")
  resourceActionId     Int      @map("resource_action_id")
  permit               Boolean
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  role           Role           @relation(fields: [roleId], references: [roleId], onDelete: Cascade)
  resourceAction ResourceAction @relation(fields: [resourceActionId], references: [resourceActionId], onDelete: Cascade)

  createdByUser User @relation("RoleResourceActionCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RoleResourceActionUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([roleId, resourceActionId])
  @@map("role_resource_action")
}

model Resource {
  resourceId Int      @id @default(autoincrement()) @map("resource_id")
  name       String   @db.NVarChar(255)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("ResourceCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("ResourceUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  resourceAction ResourceAction[]

  @@map("resource")
}

model Action {
  actionId  Int      @id @default(autoincrement()) @map("action_id")
  name      String   @db.NVarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("ActionCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("ActionUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  resourceAction ResourceAction[]

  @@map("action")
}

model Recurrence {
  recurrenceId             Int      @id @default(autoincrement()) @map("recurrence_id")
  recurrenceCancellationId Int?     @map("recurrence_cancellation_id")
  recurrenceExceptionId    Int?     @map("recurrence_exception_id")
  rule                     String   @db.NVarChar(255)
  description              String   @db.NVarChar(1000)
  startDate                DateTime @map("start_date")
  endDate                  DateTime @map("end_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  event                  Event[]
  recurrenceCancellation RecurrenceCancellation? @relation(fields: [recurrenceCancellationId], references: [recurrenceCancellationId])
  recurrenceException    RecurrenceException?    @relation(fields: [recurrenceExceptionId], references: [recurrenceExceptionId])

  createdByUser User @relation("RecurrenceCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RecurrenceUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("recurrence")
}

model RecurrenceCancellation {
  recurrenceCancellationId Int      @id @default(autoincrement()) @map("recurrence_cancellation_id")
  recurrenceDate           DateTime @map("recurrence_date")
  cancellationDate         DateTime @map("cancellation_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  recurrence Recurrence[]

  createdByUser User @relation("RecurrenceCancellationCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RecurrenceCancellationUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("recurrence_cancellation")
}

model RecurrenceException {
  recurrenceExceptionId Int      @id @default(autoincrement()) @map("recurrence_exception_id")
  recurrenceDate        DateTime @map("recurrence_date")
  rescheduledDate       DateTime @map("rescheduled_date")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  recurrence Recurrence[]

  createdByUser User @relation("RecurrenceExceptionCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("RecurrenceExceptionUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("recurrence_exception")
}

model Event {
  eventId     Int      @id @default(autoincrement()) @map("event_id")
  statusId    Int      @map("status_id")
  userId      Int?     @map("user_id")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  title       String   @db.NVarChar(255)
  description String   @db.NVarChar(1000)

  recurrenceId Int? @map("recurrence_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  recurrence Recurrence? @relation(fields: [recurrenceId], references: [recurrenceId], onDelete: Cascade)

  user User? @relation(fields: [userId], references: [id])

  status Status @relation(fields: [statusId], references: [statusId])

  createdByUser User @relation("EventCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("EventUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  eventRooms      EventRoom[]
  eventItems      EventItem[]
  eventRecipients EventRecipient[]

  @@map("event")
}

model EventRoom {
  eventRoomId Int @id @default(autoincrement()) @map("event_room_id")
  eventId     Int @map("event_id")
  roomId      Int @map("room_id")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  room  Room  @relation(fields: [roomId], references: [roomId], onDelete: Cascade)

  createdByUser User @relation("EventRoomCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("EventRoomUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([eventId, roomId], name: "eventId_roomId")
  @@map("event_room")
}

model EventRecipient {
  eventRecipientId Int @id @default(autoincrement()) @map("event_recipient_id")
  eventId          Int
  userId           Int

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("EventRecipientCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("EventRecipientUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  event Event @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([eventId, userId], name: "eventId_userId")
  @@map("event_recipient")
}

model EventItem {
  eventItemId Int      @id @default(autoincrement()) @map("event_item_id")
  eventId     Int      @map("event_id")
  itemId      Int      @map("item_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("EventItemCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updatedByUser User @relation("EventItemUpdatedBy", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  event Event @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  item  Item  @relation(fields: [itemId], references: [itemId], onDelete: Cascade)

  @@unique([eventId, itemId], name: "eventId_itemId")
  @@map("event_item")
}

model Item {
  itemId    Int      @id @default(autoincrement()) @map("item_id")
  name      String   @unique @db.NVarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdBy Int @map("created_by")
  updatedBy Int @map("updated_by")

  createdByUser User @relation("ItemCreatedBy", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
